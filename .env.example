# ---------------------------------------------------------------------------
# Multi-Agent AI Deep Researcher — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# ---------------------------------------------------------------------------

# --- Supabase (public: safe to expose to the browser) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (anon) key — sb_publishable_... — safe for the client bundle.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only secret, OPTIONAL) ---
# Service-role key. Bypasses RLS. The app itself uses only user-scoped clients,
# so this is optional and kept for admin/ops tasks. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (BYOK — there is deliberately NO server API key) ---
# This app is Bring-Your-Own-Key: each user supplies their own OpenRouter key in
# the UI. It is held in their browser, sent per request, used in memory only,
# and never stored server-side. Do NOT add an OPENROUTER_API_KEY here — the app
# must never fall back to a shared key.
#
# Model id used for all LLM calls. Free-tier friendly default.
# NOTE: do not use "openrouter/free" — that router can select models unsuited to
# structured output (we saw it pick a content-safety classifier).
OPENROUTER_MODEL=tencent/hy3:free
# Optional attribution headers sent to OpenRouter.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Multi-Agent AI Deep Researcher

# --- Tavily web search (server-only secret) ---
TAVILY_API_KEY=

# --- Resend (OPTIONAL: transactional email sent by this app) ---
# Get a key at https://resend.com/api-keys. Leave blank to disable email.
# NOTE: this is separate from Supabase auth emails (signup confirmation), which
# are configured as Custom SMTP in the Supabase dashboard using the SAME key:
#   host smtp.resend.com | port 587 | user "resend" | pass <RESEND_API_KEY>
RESEND_API_KEY=
# Sender address. Must be on a domain you verified in Resend.
# `onboarding@resend.dev` works without a domain but ONLY delivers to the
# Resend account owner's own email address.
EMAIL_FROM=onboarding@resend.dev

# --- Feature flags ---
# When "true", a clearly-labelled cached demo run is reachable from the UI.
DEMO_SAFE_MODE=true
