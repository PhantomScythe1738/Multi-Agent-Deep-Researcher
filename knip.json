{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["middleware.ts", "next.config.ts", "tests/**/*.test.ts"],
  "project": ["**/*.{ts,tsx}"],
  "ignore": ["supabase/functions/**"],
  "ignoreDependencies": [],
  "next": {
    "entry": [
      "app/**/{page,layout,loading,error,not-found,route,template,default,global-error}.{ts,tsx}",
      "app/**/{sitemap,robots,manifest,icon,apple-icon,opengraph-image,twitter-image}.{ts,tsx}",
      "instrumentation.ts"
    ]
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.test.ts"]
  }
}
