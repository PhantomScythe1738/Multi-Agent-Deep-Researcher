{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["tests/**/*.test.ts"],
  "project": ["**/*.{ts,tsx}"],
  "ignore": ["supabase/functions/**"],
  "ignoreDependencies": [
    "tailwindcss",
    "@tailwindcss/typography",
    "eslint-config-next",
    "supabase"
  ],
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["tests/**/*.test.ts"]
  }
}
